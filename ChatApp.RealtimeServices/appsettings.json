{
  "Realtime": {
    "ServiceName": "ChatApp.RealtimeServices",
    "InstanceId": "local-dev",
    "WorkerIntervalMs": 1000,
    "EnableDetailedErrors": false
  },
  "Nats": {
    "Url": "nats://localhost:4222",
    "QueueGroup": "chatapp-realtime-services",
    "Subjects": {
      "IncomingMessages": "chat.incoming-messages",
      "RealtimeEvents": "chat.realtime-events",
      "MessagePersistence": "chat.message-persistence"
    }
  },
  "ConnectionStrings": {
    "Garnet": "127.0.0.1:6379,abortConnect=false",
    "RealtimeDatabase": "Host=localhost;Port=5432;Database=ChatAppDatabase;Username=postgres;Password=520666;Include Error Detail=true;Pooling=true;Minimum Pool Size=0;Maximum Pool Size=100;Connection Idle Lifetime=300;"
  },
  "RealtimeDatabase": {
    "Schema": "realtime",
    "MessageStoreProvider": "Npgsql",
    "InitializeSchemaOnStart": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Warning"
    }
  }
}
